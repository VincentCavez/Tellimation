{
  "id": "I2",
  "name": "Nametag",
  "category": "Identity",
  "mode": "both",
  "scaffolding_intent": "Displays a floating label with ellipsis attached to the entity, inviting the child to name it",
  "misl_elements": [
    "CH"
  ],
  "target_type": ["entity","duo","group"],
  "parameters": [
    {
      "name": "bgColor",
      "type": "rgb_vary",
      "range": [
        0,
        255
      ],
      "default": [
        255,
        248,
        220
      ],
      "description": "Label background color (cream)"
    },
    {
      "name": "textColor",
      "type": "rgb_vary",
      "range": [
        0,
        255
      ],
      "default": [
        30,
        30,
        30
      ],
      "description": "Label text color (black)"
    },
    {
      "name": "stringColor",
      "type": "rgb_vary",
      "range": [
        0,
        255
      ],
      "default": [
        139,
        90,
        43
      ],
      "description": "Label border / string color (brown)"
    },
    {
      "name": "scale",
      "type": "float",
      "range": [
        1.0,
        2.0
      ],
      "default": 1.0,
      "description": "Size multiplier for the nametag label"
    }
  ],
  "code_template": "nametag({target}, {bgColor}, {textColor}, {stringColor})",
  "correction_intent": "Child described an entity with an incorrect name",
  "suggestion_intent": "Child could give a name to an entity to enrich their narrative"
}
